generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(cuid())
  name                 String
  email                String
  password             String
  role                 String             @default("member")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  teamId               String?
  activityLogs         ActivityLog[]
  announcementsCreated Announcement[]
  dailyUpdates         DailyUpdate[]
  learnings            Learning[]
  notifications        Notification[]
  moduleReviews        ModuleReview[]
  researchDocs         ResearchDocument[]
  tasks                Task[]             @relation("AssignedTasks")
  toolUsages           ToolUsage[]
  team                 Team?              @relation(fields: [teamId], references: [id])

  @@index([teamId], map: "User_teamId_fkey")
  @@unique([email, role])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  members     User[]
}

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?
  status       String   @default("pending")
  priority     String   @default("medium")
  assignedToId String?
  teamId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedTo   User?    @relation("AssignedTasks", fields: [assignedToId], references: [id])
  team         Team?    @relation(fields: [teamId], references: [id])

  @@index([assignedToId], map: "Task_assignedToId_fkey")
  @@index([teamId], map: "Task_teamId_fkey")
}

model DailyUpdate {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  todaysTasks    String   @map("workedOn")
  completedTasks String?
  blockers       String?
  tomorrowPlan   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "DailyUpdate_userId_fkey")
}

model Learning {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String
  category      String
  referenceLink String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Learning_userId_fkey")
}

model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  toolName  String
  category  String
  purpose   String
  timeSpent String
  outcome   String?
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ToolUsage_userId_fkey")
}

model ResearchDocument {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  category    String
  fileUrl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ResearchDocument_userId_fkey")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entityType  String
  entityId    String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ActivityLog_userId_fkey")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  important Boolean  @default(false)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Notification_userId_fkey")
  @@index([expiresAt])
}

model ModuleReview {
  id         String   @id @default(cuid())
  userId     String
  module     String
  reviewedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String
  createdById String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById], map: "Announcement_createdById_fkey")
}
